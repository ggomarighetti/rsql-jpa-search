{
  "perspectives": [
    {
      "label": "V2 Maven modules",
      "description": "Direct v2 module DAG for the publishable jpa-rsql-search reactor.",
      "language": "java",
      "qualifiers": "namespace",
      "groups": [
        {
          "label": "API",
          "patterns": [
            "jpa-rsql-search-api:**"
          ]
        },
        {
          "label": "RSQL SPI",
          "patterns": [
            "jpa-rsql-search-rsql-spi:**"
          ]
        },
        {
          "label": "Core",
          "patterns": [
            "jpa-rsql-search-core:**"
          ]
        },
        {
          "label": "JPA validation",
          "patterns": [
            "jpa-rsql-search-jpa-validation:**"
          ]
        },
        {
          "label": "Perplexhub",
          "patterns": [
            "jpa-rsql-search-perplexhub:**"
          ]
        },
        {
          "label": "Spring Boot starter",
          "patterns": [
            "jpa-rsql-search-spring-boot-starter:**"
          ]
        }
      ],
      "constraints": [
        {
          "relation": "exclusive-allow",
          "from": [
            "RSQL SPI",
            "Core",
            "JPA validation",
            "Perplexhub",
            "Spring Boot starter"
          ],
          "to": [
            "API"
          ]
        },
        {
          "relation": "exclusive-allow",
          "from": [
            "Core",
            "Perplexhub",
            "Spring Boot starter"
          ],
          "to": [
            "RSQL SPI"
          ]
        },
        {
          "relation": "exclusive-allow",
          "from": [
            "JPA validation",
            "Perplexhub",
            "Spring Boot starter"
          ],
          "to": [
            "Core"
          ]
        },
        {
          "relation": "exclusive-allow",
          "from": [
            "Spring Boot starter"
          ],
          "to": [
            "JPA validation"
          ]
        },
        {
          "relation": "exclusive-allow",
          "from": [
            "Spring Boot starter"
          ],
          "to": [
            "Perplexhub"
          ]
        }
      ]
    }
  ]
}
